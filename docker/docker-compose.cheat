% docker-compose

# 构建、创建、启动并附加到所有服务的容器
docker-compose up

# 构建、创建、启动所有服务的容器（后台运行）
docker-compose up -d

# 构建、创建、启动并附加到指定服务的容器
docker-compose up -d <service_name>

# 构建、创建、启动指定服务的容器（后台运行）
docker-compose up -d <service_name>

# 查看服务日志最后 100 行
docker-compose logs --tail 100 <service_name> | less

# 查看服务日志最后 100 行并持续跟踪
docker-compose logs -f --tail 100 <service_name>

# 停止容器并删除 up 创建的网络和容器
docker-compose down
